# Copy this file to .env and add your Google API key
# The same key works for Solar API, Geocoding, Street View, and Maps Static
GOOGLE_SOLAR_API_KEY=your_api_key_here

# Optional: Regrid API key for accurate parcel/lot boundary data
# Sign up at https://regrid.com/api — free tier available
# Without this, lot boundaries are estimated rectangles
REGRID_API_KEY=
